# ============================================================
# NEXUS Hedera Agent — Environment Configuration
# ============================================================
# To get testnet credentials:
#   1. Run: npx ts-node src/scripts/create-testnet-account.ts
#   OR
#   2. Visit: https://portal.hedera.com → create testnet account
# ============================================================

# Hedera Testnet Credentials (required)
HEDERA_ACCOUNT_ID=0.0.XXXXXXX
HEDERA_PRIVATE_KEY=<your-ed25519-private-key-hex>
HEDERA_NETWORK=testnet

# Deployed contract IDs (populated after first verify-testnet.ts run)
HEDERA_NFT_TOKEN_ID=0.0.XXXXXXX
HEDERA_ATTESTATION_TOPIC_ID=0.0.XXXXXXX

# Anthropic AI (for compliance analysis)
ANTHROPIC_API_KEY=sk-ant-...

# IPFS (Pinata free tier — https://app.pinata.cloud)
PINATA_JWT=eyJ...
PINATA_GATEWAY=https://gateway.pinata.cloud

# HOL Registry
HOL_OPERATOR_KEY=302e...

# Server
PORT=3000
NODE_ENV=development
